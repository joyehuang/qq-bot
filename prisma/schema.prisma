// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id              Int           @id @default(autoincrement())
  qqNumber        String        @unique @map("qq_number")
  nickname        String
  streakDays      Int           @default(0) @map("streak_days")      // 当前连续打卡天数
  maxStreak       Int           @default(0) @map("max_streak")       // 历史最长连续天数
  lastCheckinDate DateTime?     @map("last_checkin_date")            // 最后打卡日期
  dailyGoal       Int?          @map("daily_goal")                   // 每日目标（分钟）
  aiStyle         String        @default("encourage") @map("ai_style") // AI 风格：encourage/strict/funny/professional/ridicule/teacher
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  checkins        Checkin[]
  achievements    Achievement[]

  @@map("users")
}

// 打卡记录表
model Checkin {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  groupId     String   @map("group_id")
  duration    Int      // 时长（分钟）
  content     String   // 打卡内容
  isLoan      Boolean  @default(false) @map("is_loan") // 是否是贷款打卡
  category    String?  // 一级分类：学习、工作、运动、娱乐、其他
  subcategory String?  // 二级分类：计算机、英语、其他学习等
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("checkins")
}

// 功能建议表
model Suggestion {
  id        Int      @id @default(autoincrement())
  qqNumber  String   @map("qq_number")
  nickname  String
  groupId   String   @map("group_id")
  content   String   // 建议内容
  status    String   @default("pending") // pending, accepted, rejected, completed
  createdAt DateTime @default(now()) @map("created_at")

  @@map("suggestions")
}

// 用户成就表
model Achievement {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  achievementId String  @map("achievement_id") // 成就标识符
  unlockedAt   DateTime @default(now()) @map("unlocked_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, achievementId])
  @@map("achievements")
}

// AI 调用记录表（hermes 调用埋点 → 后台 dashboard）
model AICallLog {
  id               Int      @id @default(autoincrement())
  scenario         String                                // 场景：classify / checkin_reply / reminder / streak_warning / streak_broken / user_analysis / weekly_user / weekly_group
  callerQQ         String?  @map("caller_qq")           // 触发该 AI 调用的用户 QQ（如适用）
  groupQQ          String?  @map("group_qq")            // 群号（如适用）
  model            String?                               // 实际使用的 model（hermes CLI 不强制返回，可选）
  systemPrompt     String   @map("system_prompt")
  userPrompt       String   @map("user_prompt")
  responseText     String?  @map("response_text")       // 失败/超时时为 null
  durationMs       Int      @map("duration_ms")
  status           String                                // success / error / timeout
  errorMsg         String?  @map("error_msg")
  promptTokens     Int?     @map("prompt_tokens")       // 预留：当前 hermes -Q 不输出
  completionTokens Int?     @map("completion_tokens")   // 预留
  sessionId        String?  @map("session_id")          // hermes session_id（可用于 --resume 复现）
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([scenario, createdAt])
  @@index([callerQQ])
  @@index([status])
  @@map("ai_call_logs")
}

