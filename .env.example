# QQ Bot 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ============================================
# 数据库
# ============================================
# Prisma SQLite — 路径相对于 prisma/schema.prisma 所在目录，最终落在 prisma/dev.db
DATABASE_URL="file:./dev.db"

# ============================================
# GitHub Container Registry 配置
# ============================================
# 用于从 GHCR 拉取私有镜像（如果仓库是私有的）
# 创建方式：GitHub Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
# 权限：read:packages
GHCR_TOKEN=ghp_your_github_personal_access_token_here
GITHUB_REPOSITORY_OWNER=joyehuang

# ============================================
# QQ Bot 配置
# ============================================
# AI 调用通过本地 Hermes Agent CLI 完成（默认使用 community profile）。
# 无需配置远程 API key —— Hermes 自身密钥见 ~/.hermes/.env。

# NapCat WebSocket 地址（host PM2 部署默认 localhost；napcat 在 docker compose 里暴露 6100）
WS_URL="ws://localhost:6100"

# 管理员 QQ 号（用于打卡督促和管理命令鉴权）
ADMIN_QQ="your_admin_qq_number"

# 打卡督促配置
REMINDER_GROUP_ID="your_group_id"
REMINDER_HOUR="19"
REMINDER_MINUTE="0"
REMINDER_TIMEZONE="Australia/Melbourne"

# ============================================
# 管理后台配置
# ============================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here
JWT_SECRET=your_jwt_secret_key_here
